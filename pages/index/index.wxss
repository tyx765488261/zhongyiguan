.page {
  min-height: 100vh;
}

.banner {
  position: relative;
  margin: 24rpx 24rpx 0;
  border-radius: 24rpx;
  overflow: hidden;
  background: linear-gradient(145deg, #1a4d3e 0%, #2d6b52 45%, #1a4d3e 100%);
  box-shadow: 0 12rpx 40rpx rgba(26, 77, 62, 0.35);
}

.banner-pattern {
  position: absolute;
  inset: 0;
  opacity: 0.12;
  background-image: radial-gradient(circle at 20% 30%, #fff 0%, transparent 45%),
    radial-gradient(circle at 80% 70%, #c9a962 0%, transparent 40%);
}

.banner-inner {
  position: relative;
  padding: 48rpx 40rpx 56rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.banner-tag {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
}

.banner-title {
  font-size: 52rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 12rpx;
  margin-bottom: 12rpx;
}

.banner-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
}

.section {
  margin: 32rpx 24rpx 0;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 28rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #2c3e36;
}

.section-title-line {
  width: 48rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #c9a962, transparent);
}

.entry-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 20rpx;
}

.entry-item {
  width: calc(50% - 10rpx);
  box-sizing: border-box;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(201, 169, 98, 0.25);
}

.entry-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #e8f0eb 0%, #d4e5dd 100%);
  color: #1a4d3e;
  font-size: 36rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  border: 2rpx solid rgba(26, 77, 62, 0.15);
}

.entry-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c3e36;
  margin-bottom: 8rpx;
}

.entry-desc {
  font-size: 22rpx;
  color: #888;
}

.section--news {
  margin-top: 40rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 4rpx;
}

.section-head-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2c3e36;
}

.section-head-more {
  font-size: 24rpx;
  color: #1a4d3e;
}

.news-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.news-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  border-left: 6rpx solid #c9a962;
}

.news-main {
  flex: 1;
  min-width: 0;
}

.news-title {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.news-meta {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.news-tag {
  font-size: 20rpx;
  color: #1a4d3e;
  background: rgba(26, 77, 62, 0.08);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.news-date {
  font-size: 22rpx;
  color: #999;
}

.news-arrow {
  font-size: 40rpx;
  color: #ccc;
  margin-left: 16rpx;
  line-height: 1;
}

.footer {
  text-align: center;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 48rpx;
  padding: 0 24rpx;
}
