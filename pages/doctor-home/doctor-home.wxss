.page {
  min-height: 100vh;
  background-color: #f5f0e8;
  padding-bottom: 140rpx;
}

/* 医生头部 */
.doctor-header {
  background: #fff;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
}

.header-main {
  display: flex;
  margin-bottom: 40rpx;
}

.doctor-avatar {
  position: relative;
  margin-right: 32rpx;
}

.avatar-box {
  width: 140rpx;
  height: 140rpx;
  background: #1a4d3e;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  font-weight: 600;
}

.auth-tag {
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #e0d0b0;
  color: #8b6f2e;
  font-size: 18rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  white-space: nowrap;
  border: 2rpx solid #fff;
}

.doctor-info {
  flex: 1;
}

.name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.doctor-name {
  font-size: 44rpx;
  font-weight: 600;
  color: #333;
}

.follow-btn {
  font-size: 24rpx;
  color: #1a4d3e;
  background: #f0f7f2;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(26, 77, 62, 0.2);
}

.title-row {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.split-line {
  margin: 0 16rpx;
  color: #eee;
}

.stats-row {
  font-size: 26rpx;
  color: #999;
}

.stat-item {
  margin-right: 32rpx;
}

.stat-num {
  color: #c9a962;
  font-weight: 600;
}

/* 擅长领域 */
.specialty-section {
  position: relative;
  padding-top: 32rpx;
  border-top: 1rpx solid #f5f5f5;
}

.specialty-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #c9a962;
  margin-right: 16rpx;
}

.specialty-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.more-link {
  font-size: 26rpx;
  color: #c9a962;
  margin-left: 8rpx;
}

/* 通用标题 */
.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  padding: 32rpx;
  background: #fff;
  position: relative;
}

.section-title::after {
  content: '';
  position: absolute;
  left: 32rpx;
  bottom: 24rpx;
  width: 40rpx;
  height: 6rpx;
  background: #c9a962;
  border-radius: 3rpx;
}

/* 门诊挂号 */
.appoint-section {
  background: #fff;
  padding-bottom: 32rpx;
  margin-bottom: 24rpx;
}

.date-scroll {
  white-space: nowrap;
  padding: 0 32rpx 32rpx;
}

.date-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 140rpx;
  padding: 24rpx 0;
  background: #fcfbf8;
  border: 1rpx solid #f0ebe0;
  border-radius: 16rpx;
  margin-right: 20rpx;
}

.date--active {
  background: #fef9f0;
  border-color: #c9a962;
}

.date-val {
  font-size: 24rpx;
  color: #c9a962;
  margin-bottom: 8rpx;
}

.date-week {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.date--active .date-week {
  color: #c9a962;
}

.date-status {
  font-size: 22rpx;
  color: #999;
}

.date--active .date-status {
  color: #c9a962;
}

.appoint-list {
  padding: 0 32rpx;
}

.appoint-group {
  border: 1rpx solid rgba(201, 169, 98, 0.15);
  border-radius: 20rpx;
  padding: 32rpx;
}

.group-header {
  margin-bottom: 32rpx;
}

.location-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.location-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.time-tag {
  font-size: 20rpx;
  background: #f0f7f2;
  color: #1a4d3e;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.address {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.source-info {
  font-size: 26rpx;
  color: #666;
}

.source-num {
  color: #c9a962;
  font-weight: 600;
}

.time-slot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fcfbf8;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.slot-left {
  display: flex;
  flex-direction: column;
}

.slot-time {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.slot-remain {
  font-size: 24rpx;
  color: #c9a962;
}

.slot-right {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.slot-price {
  font-size: 32rpx;
  color: #e74c3c;
  font-weight: 600;
}

.btn-sub-appoint {
  background: #c9a962;
  color: #fff;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* 患者评价 */
.review-section {
  background: #fff;
  padding: 0 32rpx 32rpx;
}

.review-card {
  padding: 32rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.review-user {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.user-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #eee;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #999;
  margin-right: 20rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}

.rating {
  color: #ffb400;
  font-size: 20rpx;
}

.review-date {
  font-size: 24rpx;
  color: #ccc;
}

.review-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.review-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.r-tag {
  font-size: 22rpx;
  color: #1a4d3e;
  background: rgba(26, 77, 62, 0.05);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

/* 底部操作栏 */
.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: #fff;
  display: flex;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.action-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  font-size: 30rpx;
  color: #1a4d3e;
  font-weight: 500;
}

.action-item:first-child {
  border-right: 1rpx solid #f5f5f5;
}

.action-icon {
  font-size: 36rpx;
}

/* 健康助理浮层 (通用) */
.fab {
  position: fixed;
  right: 24rpx;
  bottom: 140rpx;
  background: #fff;
  padding: 12rpx 24rpx;
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(201, 169, 98, 0.25);
  border: 1rpx solid rgba(201, 169, 98, 0.25);
  z-index: 100;
}

.fab-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #1a4d3e;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 16rpx;
}

.fab-text-wrap {
  display: flex;
  flex-direction: column;
}

.fab-line {
  font-size: 24rpx;
  color: #1a4d3e;
}

.fab-line--sub {
  font-size: 20rpx;
  color: #c9a962;
}