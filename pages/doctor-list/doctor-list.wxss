.page {
  min-height: 100vh;
  background-color: #f5f0e8;
  display: flex;
  flex-direction: column;
}

/* 日期选择器 */
.date-bar {
  background: #fff;
  white-space: nowrap;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.date-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 28rpx;
  min-width: 112rpx;
  vertical-align: top;
}

.date-item--unlimited {
  min-width: 140rpx;
}

.date-unlimited {
  font-size: 26rpx;
  color: #666;
}

.date-week {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.date-day {
  font-size: 28rpx;
  color: #333;
}

.date-item--active .date-week,
.date-item--active .date-day,
.date-item--active .date-unlimited {
  color: #c9a962;
  font-weight: 600;
}

.date-item--active {
  background: rgba(201, 169, 98, 0.12);
  border-radius: 12rpx;
}

.date-more {
  display: inline-flex;
  align-items: center;
  padding: 0 24rpx;
  border-left: 1rpx solid #eee;
  gap: 6rpx;
}

.date-more-icon {
  font-size: 30rpx;
}

.date-more-arrow {
  font-size: 16rpx;
  color: #999;
}

/* 筛选栏：三列下拉 */
.filter-bar--row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 16rpx 20rpx;
  gap: 8rpx;
}

.filter-cell {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #333;
}

.filter-cell--open .filter-cell-text,
.filter-cell--open .filter-arrow {
  color: #c9a962;
  font-weight: 600;
}

.filter-cell-text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 200rpx;
}

.filter-cell-text--muted {
  color: #333;
}

.filter-arrow {
  font-size: 16rpx;
  margin-left: 8rpx;
  flex-shrink: 0;
}

.filter-arrow--muted {
  color: #999;
}

/* 科室 / 疾病 级联面板 */
.cascade-overlay {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 400;
}

.cascade-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
}

.cascade-panel {
  position: absolute;
  left: 0;
  right: 0;
  top: 200rpx;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.08);
}

.cascade-split {
  display: flex;
  height: 100%;
}

.cascade-side {
  width: 42%;
  height: 100%;
  background: #f7f7f7;
  border-right: 1rpx solid #ededed;
}

.cascade-side-item {
  position: relative;
  padding: 28rpx 20rpx 28rpx 24rpx;
  display: flex;
  align-items: center;
}

.cascade-side-bar {
  position: absolute;
  left: 0;
  top: 20rpx;
  bottom: 20rpx;
  width: 6rpx;
  border-radius: 0 4rpx 4rpx 0;
  background: transparent;
}

.cascade-side-item--on .cascade-side-bar {
  background: linear-gradient(180deg, #d4a84b, #c9a962);
}

.cascade-side-item--on .cascade-side-text {
  color: #c9a962;
  font-weight: 600;
}

.cascade-side-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.35;
}

.cascade-main {
  flex: 1;
  min-width: 0;
  height: 100%;
  background: #fff;
}

.cascade-main-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.cascade-main-text {
  font-size: 28rpx;
  color: #333;
}

.cascade-main-check {
  font-size: 30rpx;
  color: #c9a962;
  font-weight: 700;
}

/* 地区筛选面板 */
.region-overlay {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 410;
}

.region-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
}

.region-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 70vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.08);
}

/* 固定高度：仅 max-height 时父级高度随内容撑满，scroll-view 的 100% 无效，底部会被裁切且无法滑动 */
.region-panel--cascade {
  height: 75vh;
  max-height: 75vh;
}

.region-title {
  padding: 28rpx 32rpx 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

/* min-height:0 允许 flex 子项低于内容高度，内部 scroll-view 才能出现滚动条 */
.region-cascade-body {
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.region-cascade-body.cascade-split {
  height: 100%;
}

/* 医生姓名搜索 */
.name-search {
  margin: 16rpx 20rpx 0;
  background: #fff;
  border-radius: 12rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(201, 169, 98, 0.25);
}

.name-search-icon {
  font-size: 26rpx;
  color: #bbb;
  margin-right: 12rpx;
}

.name-search-input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  height: 72rpx;
  line-height: 72rpx;
}

.name-search-ph {
  color: #bbb;
}

.name-search-clear {
  font-size: 24rpx;
  color: #1a4d3e;
  margin-left: 16rpx;
}

/* 医生列表 */
.doctor-scroll {
  flex: 1;
  padding: 20rpx;
  box-sizing: border-box;
}

.doctor-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.doctor-main {
  display: flex;
  margin-bottom: 24rpx;
}

.doctor-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #1a4d3e;
  margin-right: 24rpx;
}

.avatar-img {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 40rpx;
}

.doctor-info {
  flex: 1;
  min-width: 0;
}

.info-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.doctor-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.doctor-title, .doctor-dept {
  font-size: 24rpx;
  color: #666;
}

.doctor-hospital {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 10rpx;
}

.doctor-specialty {
  font-size: 24rpx;
  color: #888;
  line-height: 1.4;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.doctor-stats {
  font-size: 24rpx;
  color: #999;
}

.stat-item {
  margin-right: 24rpx;
}

.stat-num {
  color: #c9a962;
  font-weight: 600;
}

.doctor-arrow {
  color: #ccc;
  font-size: 40rpx;
}

/* 排班列表 */
.schedule-list {
  border-top: 1rpx solid #f5f5f5;
  padding-top: 20rpx;
}

.schedule-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.sch-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.sch-name {
  font-size: 28rpx;
  color: #333;
}

.sch-tag {
  font-size: 20rpx;
  background: #f0f0f0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  color: #666;
}

.sch-btn {
  background: #c9a962;
  color: #fff;
  font-size: 24rpx;
  padding: 0 30rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 28rpx;
  margin: 0;
}

.sch-btn--hollow {
  background: transparent;
  color: #c9a962;
  border: 1rpx solid #c9a962;
}

/* 健康助理浮层 (同 dept.wxss) */
.fab {
  position: fixed;
  right: 24rpx;
  bottom: 60rpx;
  background: #fff;
  padding: 12rpx 24rpx;
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(201, 169, 98, 0.25);
  border: 1rpx solid rgba(201, 169, 98, 0.25);
  z-index: 100;
}

.fab-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #c9a962;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 16rpx;
}

.fab-text-wrap {
  display: flex;
  flex-direction: column;
}

.fab-line {
  font-size: 24rpx;
  color: #1a4d3e;
  font-weight: 500;
}

.fab-line--sub {
  font-size: 20rpx;
  color: #c9a962;
}