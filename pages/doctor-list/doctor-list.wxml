<view class="page">
  <!-- 日期 -->
  <scroll-view class="date-bar" scroll-x>
    <view
      class="date-item {{selectedDate === index ? 'date-item--active' : ''}} {{item.unlimited ? 'date-item--unlimited' : ''}}"
      wx:for="{{dateList}}"
      wx:key="index"
      bindtap="onDateTap"
      data-index="{{index}}"
    >
      <block wx:if="{{item.unlimited}}">
        <text class="date-unlimited">不限时间</text>
      </block>
      <block wx:else>
        <text class="date-day">{{item.day}}</text>
        <text class="date-week">{{item.week}}</text>
      </block>
    </view>
    <view class="date-more" bindtap="noop">
      <text class="date-more-icon">📅</text>
      <text class="date-more-arrow">▼</text>
    </view>
  </scroll-view>

  <!-- 三列筛选：科室 | 全国 | 疗效好 -->
  <view class="filter-bar filter-bar--row">
    <view
      class="filter-cell {{deptPickerOpen ? 'filter-cell--open' : ''}}"
      bindtap="onDeptFilterBarTap"
    >
      <text class="filter-cell-text">{{deptFilterDisplay}}</text>
      <text class="filter-arrow">▼</text>
    </view>
    <view
      class="filter-cell {{regionPickerOpen ? 'filter-cell--open' : ''}}"
      bindtap="onRegionFilterTap"
    >
      <text class="filter-cell-text {{!locationId ? 'filter-cell-text--muted' : ''}}">{{regionFilterDisplay}}</text>
      <text class="filter-arrow {{!locationId ? 'filter-arrow--muted' : ''}}">▼</text>
    </view>
    <view class="filter-cell" bindtap="onSortFilterTap">
      <text class="filter-cell-text filter-cell-text--muted">疗效好</text>
      <text class="filter-arrow filter-arrow--muted">▼</text>
    </view>
  </view>

  <!-- 医生姓名 -->
  <view class="name-search">
    <text class="name-search-icon">⌕</text>
    <input
      class="name-search-input"
      type="text"
      value="{{keyword}}"
      placeholder="输入医生姓名筛选"
      placeholder-class="name-search-ph"
      bindinput="onKeywordInput"
      bindconfirm="onKeywordConfirm"
      confirm-type="search"
    />
    <text wx:if="{{keyword}}" class="name-search-clear" bindtap="onClearKeyword">清空</text>
  </view>

  <!-- 医生列表 -->
  <scroll-view class="doctor-scroll" scroll-y>
    <view class="doctor-card" wx:for="{{doctorList}}" wx:key="id">
      <view class="doctor-main">
        <view class="doctor-avatar">
          <view class="avatar-img">{{item.avatarText}}</view>
        </view>
        <view class="doctor-info">
          <view class="info-top">
            <text class="doctor-name">{{item.name}}</text>
            <text class="doctor-title">{{item.title}}</text>
            <text class="doctor-dept">| {{item.dept}}</text>
          </view>
          <view wx:if="{{item.hospital}}" class="doctor-hospital">{{item.hospital}}</view>
          <view class="doctor-specialty">擅长：{{item.specialty}}</view>
          <view class="doctor-stats">
            <text class="stat-item">粉丝 <text class="stat-num">{{item.fans}}</text></text>
            <text class="stat-item">口碑 <text class="stat-num">{{item.reputation}}</text></text>
          </view>
        </view>
        <view class="doctor-arrow">›</view>
      </view>

      <view class="schedule-list">
        <view class="schedule-item" wx:for="{{item.schedules}}" wx:for-item="sch" wx:key="index">
          <view class="sch-left">
            <text class="sch-name">{{sch.location}}</text>
            <text class="sch-tag">{{sch.timeTag}}</text>
          </view>
          <view class="sch-right">
            <button class="sch-btn" bindtap="onAppointTap" data-doctor="{{item.name}}" data-price="{{sch.price}}">
              预约 ¥{{sch.price}}
            </button>
          </view>
        </view>
        <view class="schedule-item">
          <view class="sch-left">
            <text class="sch-name">互联网医院</text>
          </view>
          <view class="sch-right">
            <button class="sch-btn sch-btn--hollow" bindtap="noop">立即复诊</button>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 科室 + 疾病 级联 -->
  <view class="cascade-overlay" wx:if="{{deptPickerOpen}}">
    <view class="cascade-mask" catchtap="onCascadeMaskTap"></view>
    <view class="cascade-panel" catchtap="noop">
      <view class="cascade-split">
        <scroll-view class="cascade-side" scroll-y>
          <view
            wx:for="{{deptLeftList}}"
            wx:for-index="idx"
            wx:key="id"
            class="cascade-side-item {{overlayDeptIndex === idx ? 'cascade-side-item--on' : ''}}"
            bindtap="onCascadeDeptTap"
            data-index="{{idx}}"
            data-id="{{item.id}}"
          >
            <view class="cascade-side-bar"></view>
            <text class="cascade-side-text">{{item.name}}</text>
          </view>
        </scroll-view>
        <scroll-view class="cascade-main" scroll-y>
          <view
            wx:for="{{illnessPanelList}}"
            wx:for-index="ix"
            wx:key="ix"
            class="cascade-main-row"
            bindtap="onCascadeIllnessTap"
            data-index="{{ix}}"
          >
            <text class="cascade-main-text">{{item.name}}</text>
            <text wx:if="{{item.checked}}" class="cascade-main-check">✓</text>
          </view>
        </scroll-view>
      </view>
    </view>
  </view>

  <!-- 地区：省 + 地级市 二级联动 -->
  <view class="region-overlay" wx:if="{{regionPickerOpen}}">
    <view class="region-mask" catchtap="onRegionMaskTap"></view>
    <view class="region-panel region-panel--cascade" catchtap="noop">
      <view class="region-title">选择地区</view>
      <view class="cascade-split region-cascade-body">
        <scroll-view class="cascade-side" scroll-y enhanced="{{true}}" show-scrollbar="{{true}}">
          <view
            wx:for="{{locationProvinceList}}"
            wx:for-index="lpi"
            wx:key="lpi"
            class="cascade-side-item {{overlayLocationProvinceIndex === lpi ? 'cascade-side-item--on' : ''}}"
            bindtap="onLocationProvinceTap"
            data-index="{{lpi}}"
            data-id="{{item.id}}"
          >
            <view class="cascade-side-bar"></view>
            <text class="cascade-side-text">{{item.name}}</text>
          </view>
        </scroll-view>
        <scroll-view class="cascade-main" scroll-y enhanced="{{true}}" show-scrollbar="{{true}}">
          <view
            wx:for="{{locationCityList}}"
            wx:for-index="lci"
            wx:key="lci"
            class="cascade-main-row"
            bindtap="onLocationCityTap"
            data-index="{{lci}}"
          >
            <text class="cascade-main-text">{{item.name}}</text>
            <text wx:if="{{item.checked}}" class="cascade-main-check">✓</text>
          </view>
        </scroll-view>
      </view>
    </view>
  </view>

  <view class="fab" bindtap="noop">
    <view class="fab-avatar">医</view>
    <view class="fab-text-wrap">
      <text class="fab-line">推荐医生问问</text>
      <text class="fab-line fab-line--sub">健康助理</text>
    </view>
  </view>
</view>
