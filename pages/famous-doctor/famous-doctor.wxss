.page {
  min-height: 100vh;
  background-color: #f5f0e8;
  display: flex;
  flex-direction: column;
}

/* 顶部标题区 */
.famous-header {
  position: relative;
  background: linear-gradient(145deg, #1a4d3e 0%, #2d6b52 100%);
  padding: 80rpx 40rpx 100rpx;
  color: #fff;
  overflow: hidden;
}

.header-inner {
  position: relative;
  z-index: 1;
}

.header-title {
  font-size: 52rpx;
  font-weight: 600;
  letter-spacing: 12rpx;
  display: block;
  margin-bottom: 12rpx;
}

.header-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
}

.header-pattern {
  position: absolute;
  inset: 0;
  opacity: 0.12;
  background-image: radial-gradient(circle at 20% 30%, #fff 0%, transparent 45%),
    radial-gradient(circle at 80% 70%, #c9a962 0%, transparent 40%);
}

/* 搜索筛选 */
.search-section {
  margin: -40rpx 24rpx 0;
  position: relative;
  z-index: 2;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.05);
}

.search-bar {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 12rpx 32rpx;
  margin-bottom: 32rpx;
}

.search-icon {
  font-size: 32rpx;
  color: #bbb;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 64rpx;
}

.ph-style {
  color: #bbb;
}

.filter-tabs {
  display: flex;
  justify-content: space-around;
}

.filter-tab {
  font-size: 28rpx;
  color: #999;
  position: relative;
  padding: 12rpx 0;
}

.tab--active {
  color: #1a4d3e;
  font-weight: 600;
}

.tab--active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 4rpx;
  background: #1a4d3e;
  border-radius: 2rpx;
}

/* 科室筛选网格 */
.dept-grid {
  display: flex;
  flex-wrap: wrap;
  margin-top: 40rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid #f0f0f0;
}

.dept-grid-item {
  width: 25%;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #333;
}

.dept--active {
  color: #c9a962;
  font-weight: 600;
}

.dept--active .dept-arrow {
  color: #c9a962;
}

.arrow--up {
  transform: rotate(180deg);
  display: inline-block;
  transition: transform 0.3s ease;
}

.dept-arrow {
  font-size: 20rpx;
  margin-left: 8rpx;
  color: #bbb;
  transition: transform 0.3s ease;
}

/* 二级科室面板 */
.sub-dept-panel {
  background: #fcfbf8;
  border-radius: 12rpx;
  margin-top: 24rpx;
  padding: 24rpx;
  border: 1rpx dashed rgba(201, 169, 98, 0.3);
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.sub-dept-title {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.sub-dept-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.sub-dept-item {
  background: #fff;
  border: 1rpx solid #eee;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
}

.sub--active {
  background: #1a4d3e;
  color: #fff;
  border-color: #1a4d3e;
}

/* 名医列表 */
.famous-list {
  flex: 1;
  padding: 24rpx;
  box-sizing: border-box;
}

.doctor-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(201, 169, 98, 0.2);
}

.card-main {
  display: flex;
  margin-bottom: 24rpx;
}

.doctor-avatar {
  position: relative;
  margin-right: 24rpx;
}

.avatar-box {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #1a4d3e;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 600;
}

.level-tag {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  background: #c9a962;
  color: #fff;
  font-size: 18rpx;
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
  white-space: nowrap;
}

.doctor-info {
  flex: 1;
  min-width: 0;
}

.info-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.doctor-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.doctor-title {
  font-size: 24rpx;
  color: #c9a962;
  font-weight: 600;
}

.doctor-dept {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.doctor-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.doctor-arrow {
  font-size: 40rpx;
  color: #ccc;
  line-height: 120rpx;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx solid #f5f5f5;
}

.footer-tags {
  display: flex;
  gap: 12rpx;
}

.f-tag {
  font-size: 20rpx;
  color: #1a4d3e;
  background: rgba(26, 77, 62, 0.08);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.btn-appoint {
  background: #c9a962;
  color: #fff;
  font-size: 24rpx;
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-weight: 600;
}

/* 健康助理浮层 */
.fab {
  position: fixed;
  right: 24rpx;
  bottom: 60rpx;
  background: #fff;
  padding: 16rpx 24rpx;
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(201, 169, 98, 0.25);
  border: 1rpx solid rgba(201, 169, 98, 0.25);
  z-index: 100;
}

.fab-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #1a4d3e;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 16rpx;
}

.fab-text-wrap {
  display: flex;
  flex-direction: column;
}

.fab-line {
  font-size: 22rpx;
  color: #1a4d3e;
}

.fab-line--sub {
  font-size: 24rpx;
  font-weight: 600;
  color: #c9a962;
}